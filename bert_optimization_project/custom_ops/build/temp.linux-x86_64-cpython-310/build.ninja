ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /usr/local/miniconda3/envs/pytorch_test/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /usr/local/miniconda3/envs/pytorch_test/include -fPIC -O2 -isystem /usr/local/miniconda3/envs/pytorch_test/include -fPIC -I/hy-tmp/pytorch/torch/include -I/hy-tmp/pytorch/torch/include/torch/csrc/api/include -I/hy-tmp/pytorch/torch/include/TH -I/hy-tmp/pytorch/torch/include/THC -I/usr/local/cuda/include -I/usr/local/miniconda3/envs/pytorch_test/include/python3.10 -c
post_cflags = -O3 -fopenmp -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1013"' -DTORCH_EXTENSION_NAME=bert_custom_gemm -D_GLIBCXX_USE_CXX11_ABI=1 -std=c++17
cuda_cflags = -I/hy-tmp/pytorch/torch/include -I/hy-tmp/pytorch/torch/include/torch/csrc/api/include -I/hy-tmp/pytorch/torch/include/TH -I/hy-tmp/pytorch/torch/include/THC -I/usr/local/cuda/include -I/usr/local/miniconda3/envs/pytorch_test/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 --use_fast_math -lineinfo --ptxas-options=-v -gencode=arch=compute_70,code=sm_70 -gencode=arch=compute_75,code=sm_75 -gencode=arch=compute_80,code=sm_80 -gencode=arch=compute_86,code=sm_86 -gencode=arch=compute_89,code=sm_89 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1013"' -DTORCH_EXTENSION_NAME=bert_custom_gemm -D_GLIBCXX_USE_CXX11_ABI=1 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /hy-tmp/bert_optimization_project/custom_ops/build/temp.linux-x86_64-cpython-310/custom_gemm.o: cuda_compile /hy-tmp/bert_optimization_project/custom_ops/custom_gemm.cu






